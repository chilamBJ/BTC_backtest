# 复制为 .env 并填写实际值（.env 已 gitignore）

# SSH
DEPLOY_PASSWORD=你的服务器密码
SYNC_ECS_SERVER=47.238.152.210
SYNC_ECS_USER=root

# Telegram Bot
TELEGRAM_BOT_TOKEN=你的机器人token
ADMIN_CHAT_ID=你的chat_id

# 可选
# SYNC_REMOTE_DIR=/root/btc_collector/collector_data
# SYNC_LOCAL_DIR=

# ---------- Trade 策略 (seller / smart_seller) 与 Dashboard ----------
# MySQL（策略与 Dashboard 共用，需先建库）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=poly
MYSQL_PASSWORD=你的MySQL密码
MYSQL_DATABASE=poly

# Polymarket 实盘（仅 --live 时需要；模拟盘可不填）
# 私钥（0x 开头的 64 位十六进制，或去掉 0x 的 64 字符）
# PRIVATE_KEY=
# 代理/钱包地址（Polymarket 下单用，与私钥对应）
# PROXY_ADDRESS=
# 或使用 WALLET_ADDRESS（与 PROXY_ADDRESS 二选一）
# WALLET_ADDRESS=

# 可选：Polygon RPC（查 USDC 余额等，不填会用公共 RPC）
# RPC_URL=https://polygon-bor-rpc.publicnode.com
